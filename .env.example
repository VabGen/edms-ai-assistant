# ═══════════════════════════════════════════════════════════════════════════
# EDMS AI Assistant — Environment Configuration Template
# Копируй этот файл в .env и заполни значениями. .env добавлен в .gitignore!
# ═══════════════════════════════════════════════════════════════════════════

# ── Application ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
APP_VERSION=0.1.0
# BUILD_COMMIT= # Устанавливается автоматически в CI/CD
API_PORT=8000
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Security (python -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ── LLM Configuration ──────────────────────────────────────────────────────
LLM_GENERATIVE_URL=http://127.0.0.1:11434/v1
LLM_GENERATIVE_MODEL=gpt-oss:120b-cloud

LLM_EMBEDDING_URL=http://model-embedding.shared.du.iba/v1
LLM_EMBEDDING_MODEL=embedding-model

# API Keys
LLM_API_KEY=
OPENAI_API_KEY=

# LLM Runtime
LLM_TEMPERATURE=0.6
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=120
LLM_MAX_RETRIES=3

# ── Embedding & Vector DB ──────────────────────────────────────────────────
EMBEDDING_DIM=1536
QDRANT_URL=http://qdrant:6333

# ── EDMS Configuration ─────────────────────────────────────────────────────
EDMS_BASE_URL=http://127.0.0.1:8098
EDMS_TIMEOUT=120
EDMS_API_VERSION=v1
EDMS_MCP_URL=http://edms-mcp:9000/mcp

# ── Database Configuration ─────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=1234
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres

# ── Redis Configuration ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=
CACHE_TTL_SECONDS=600

# ── File Upload Configuration ──────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_EXTENSIONS=.docx,.doc,.pdf,.txt,.rtf,.xlsx,.xls,.pptx

# ── Agent Configuration ────────────────────────────────────────────────────
AGENT_MAX_ITERATIONS=10
AGENT_MAX_CONTEXT_MESSAGES=20
AGENT_TIMEOUT=120.0
AGENT_LEAN_PROMPT=false

# ── Rate Limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# ── Logging Configuration ──────────────────────────────────────────────────
LOGGING_LEVEL=INFO
LOGGING_INCLUDE_TRACE_ID=true

# ── OpenTelemetry (Стандарт 2025) ──────────────────────────────────────────
OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# ── LangSmith Tracing ──────────────────────────────────────────────────────
# LANGCHAIN_TRACING_USE=true
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# LANGCHAIN_API_KEY=lsv2_pt_...
# LANGCHAIN_PROJECT=edms-ai-assistant
