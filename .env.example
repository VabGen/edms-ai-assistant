# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=production
API_PORT=8000
DEBUG=false
# Comma-separated list of allowed CORS origins, or * for any
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://next.edo.iba

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong random key:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-random-64-char-hex-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=1234
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# ── LLM (generative) ─────────────────────────────────────────────────────────
LLM_GENERATIVE_URL=http://host.docker.internal:11434/v1
LLM_GENERATIVE_MODEL=gpt-oss:120b-cloud
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=120

# ── LLM (embeddings) ─────────────────────────────────────────────────────────
LLM_EMBEDDING_URL=http://model-embedding.shared.du.iba/v1
LLM_EMBEDDING_MODEL=embedding-model

# ── LLM API keys (leave blank for local/Ollama backends) ─────────────────────
# LLM_API_KEY=
# OPENAI_API_KEY=

# ── EDMS backend ─────────────────────────────────────────────────────────────
EDMS_BASE_URL=http://host.docker.internal:8098
EDMS_TIMEOUT=120

# ── File uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=50

# ── Agent ─────────────────────────────────────────────────────────────────────
AGENT_MAX_ITERATIONS=10
AGENT_TIMEOUT=120.0

# ── Summarizer ────────────────────────────────────────────────────────────────
SUMMARIZER_CONTEXT_WINDOW=4096
SUMMARIZER_MAX_CONCURRENT_MAP=6

# ── Uvicorn workers (increase for multi-core production hosts) ────────────────
UVICORN_WORKERS=1

# ── Logging ───────────────────────────────────────────────────────────────────
LOGGING_LEVEL=INFO

# ── Telemetry / OpenTelemetry (optional) ─────────────────────────────────────
TELEMETRY_ENABLED=false
# TELEMETRY_ENDPOINT=http://jaeger:4318
