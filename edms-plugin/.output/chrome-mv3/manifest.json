{
  "manifest_version": 3,
  "name": "EDMS AI Assistant",
  "description": "AI-powered assistant for EDMS document management",
  "version": "2.0.0",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "http://localhost:3000/*",
    "http://localhost:3001/*",
    "http://localhost:8080/*",
    "http://localhost:8000/*",
    "https://next.edo.iba/*",
    "http://127.0.0.1:*/*",
    "https://127.0.0.1:*/*"
  ],
  "commands": {
    "wxt:reload-extension": {
      "description": "Reload the extension during development",
      "suggested_key": {
        "default": "Alt+R"
      }
    }
  },
  "background": {
    "type": "module",
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "EDMS AI Assistant",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "content-scripts/assistant.css"
      ],
      "matches": [
        "http://localhost:3000/*",
        "http://localhost:3001/*",
        "http://localhost:8080/*",
        "https://next.edo.iba/*",
        "http://127.0.0.1:*/*",
        "https://127.0.0.1:*/*"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval' http://localhost:3000; object-src 'self';",
    "sandbox": "script-src 'self' 'unsafe-inline' 'unsafe-eval' http://localhost:3000; sandbox allow-scripts allow-forms allow-popups allow-modals; child-src 'self';"
  }
}