# ═══════════════════════════════════════════════════════════════════════════
# EDMS AI Assistant — Production Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# SECURITY: Never commit this file to version control!

# ── Application ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
# ENVIRONMENT=production  # ← Для продакшена
API_PORT=8000
DEBUG=true
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080  # ← Для продакшена!
ALLOWED_ORIGINS=*

# ── Security ────────────────────────────────────────────────────────────────
# GENERATE: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-in-production-use-strong-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ── LLM Configuration ───────────────────
LLM_GENERATIVE_URL=http://model-generative.shared.du.iba/v1
LLM_GENERATIVE_MODEL=generative-model
LLM_EMBEDDING_URL=http://model-embedding.shared.du.iba/v1
LLM_EMBEDDING_MODEL=embedding-model

# API Keys
LLM_API_KEY=
# OPENAI_API_KEY=sk-...

# LLM Runtime
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=120
LLM_MAX_RETRIES=3
LLM_REQUEST_TIMEOUT=120
LLM_STREAM_USAGE=false

# ── Embedding Configuration ────────────────────────────────────────────────
EMBEDDING_TIMEOUT=120
EMBEDDING_MAX_RETRIES=3
EMBEDDING_REQUEST_TIMEOUT=120
EMBEDDING_CTX_LENGTH=8191
EMBEDDING_CHUNK_SIZE=1000
EMBEDDING_MAX_RETRIES_PER_REQUEST=6

# ── EDMS Configuration ─────────────────────────────────────────────────────
EDMS_BASE_URL=http://127.0.0.1:8098
EDMS_TIMEOUT=120
EDMS_API_VERSION=v1

# ── Database Configuration ─────────────────────────────────────────────────
# SECURITY: Use environment-specific credentials!
POSTGRES_USER=postgres
POSTGRES_PASSWORD=1234
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres

CHECKPOINT_DB_URL=
SQL_DB_URL=

# ── Redis Configuration ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=  # ← Для продакшена!

# ── File Upload Configuration ──────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_EXTENSIONS=.docx,.doc,.pdf,.txt,.rtf,.xlsx,.xls,.pptx

# ── Agent Configuration ────────────────────────────────────────────────────
AGENT_MAX_ITERATIONS=10
AGENT_MAX_CONTEXT_MESSAGES=20
AGENT_TIMEOUT=120.0
AGENT_ENABLE_TRACING=false  # true только для отладки
AGENT_LOG_LEVEL=INFO
AGENT_MAX_RETRIES=3

# ── RAG Configuration ──────────────────────────────────────────────────────
RAG_BATCH_SIZE=20
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=300
RAG_EMBEDDING_BATCH_SIZE=10
CHROMA_PERSIST_DIR=./chroma_db

# ── Rate Limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# ── Logging Configuration ──────────────────────────────────────────────────
LOGGING_LEVEL=DEBUG
# LOGGING_LEVEL=INFO  # ← Для продакшена
LOGGING_FORMAT=%(asctime)s [%(levelname)s] %(name)s: %(message)s
LOGGING_INCLUDE_TRACE_ID=true

# ── Telemetry & Monitoring ─────────────────────────────────────────────────
TELEMETRY_ENABLED=false
# TELEMETRY_ENABLED=true  # ← Для продакшена
TELEMETRY_ENDPOINT=
HEALTH_CHECK_ENABLED=true

# ── LangSmith Tracing ───────────────────────────────────────
# LANGSMITH_TRACING=false
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=lsv2_pt_...
# LANGSMITH_PROJECT=edms-ai-assistant