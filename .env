# ═══════════════════════════════════════════════════════════════════════════
# EDMS AI Assistant — Production Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════

# ── Application ─────────────────────────────────────────────────────────────
# production
ENVIRONMENT=development
API_PORT=8000
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Security ────────────────────────────────────────────────────────────────
# GENERATE: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-in-production-use-strong-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ── LLM Configuration ───────────────────
#LLM_GENERATIVE_URL=http://model-generative.shared.du.iba/v1
#LLM_GENERATIVE_MODEL=generative-model

#LLM_GENERATIVE_URL=https://api.proxyapi.ru/openai/v1
#LLM_GENERATIVE_MODEL=gpt-4o-mini

LLM_GENERATIVE_URL=http://127.0.0.1:11434
#LLM_GENERATIVE_URL=http://host.docker.internal:11434/v1
#LLM_GENERATIVE_MODEL=glm-5:cloud
LLM_GENERATIVE_MODEL=gpt-oss:120b-cloud

LLM_EMBEDDING_URL=http://model-embedding.shared.du.iba/v1
LLM_EMBEDDING_MODEL=embedding-model

# API Keys
LLM_API_KEY=
OPENAI_API_KEY=

# LLM Runtime
LLM_TEMPERATURE=0.6
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=120
LLM_MAX_RETRIES=3
LLM_REQUEST_TIMEOUT=120
LLM_STREAM_USAGE=false

# ── Embedding Configuration ────────────────────────────────────────────────
EMBEDDING_TIMEOUT=120
EMBEDDING_MAX_RETRIES=3
EMBEDDING_REQUEST_TIMEOUT=120
EMBEDDING_CTX_LENGTH=8191
EMBEDDING_CHUNK_SIZE=1000
EMBEDDING_MAX_RETRIES_PER_REQUEST=6
# Dimension векторов для Qdrant (должен совпадать с embedding моделью)
EMBEDDING_DIM=1536

# ── EDMS Configuration ─────────────────────────────────────────────────────
EDMS_BASE_URL=http://127.0.0.1:8098
#EDMS_BASE_URL=http://host.docker.internal:8098
EDMS_TIMEOUT=120
EDMS_API_VERSION=v1

# ── Database Configuration ─────────────────────────────────────────────────
# SECURITY: Use environment-specific credentials!
POSTGRES_USER=postgres
POSTGRES_PASSWORD=1234
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres

CHECKPOINT_DB_URL=
SQL_DB_URL=

# -----------------------------
# MCP server (FastMCP HTTP transport)
# -----------------------------
# URL к MCP эндпоинту для оркестратора (по docker-compose это http://edms-mcp:9000/mcp/)
EDMS_MCP_URL=http://edms-mcp:9000/mcp
EDMS_MCP_PORT=9000

# ── Redis Configuration ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=
CACHE_TTL_SECONDS=600

# -----------------------------
# Vector DB (Qdrant)
# -----------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_PORT=6333

# -----------------------------
# Service ports
# -----------------------------
ORCHESTRATOR_PORT=8000
FEEDBACK_PORT=8001
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# -----------------------------
# Cache / performance
# -----------------------------
CHAT_CACHE_ENABLED=true
CHAT_CACHE_TTL_S=300

# ── File Upload Configuration ──────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_EXTENSIONS=.docx,.doc,.pdf,.txt,.rtf,.xlsx,.xls,.pptx

# ── Agent Configuration ────────────────────────────────────────────────────
AGENT_MAX_ITERATIONS=10
AGENT_MAX_CONTEXT_MESSAGES=20
AGENT_TIMEOUT=120.0
# true для отладки
AGENT_ENABLE_TRACING=false
AGENT_LOG_LEVEL=INFO
AGENT_MAX_RETRIES=3
# true только если используешь малую модель
AGENT_LEAN_PROMPT=false

SETTINGS_PANEL_SHOW_TECHNICAL=true

# ── RAG Configuration ──────────────────────────────────────────────────────
RAG_BATCH_SIZE=20
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=300
RAG_EMBEDDING_BATCH_SIZE=10

# ── Rate Limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# ── Logging Configuration ──────────────────────────────────────────────────
LOGGING_LEVEL=INFO
LOGGING_FORMAT=%(asctime)s [%(levelname)s] %(name)s: %(message)s
LOGGING_INCLUDE_TRACE_ID=true

# ── Telemetry & Monitoring ─────────────────────────────────────────────────
# true
TELEMETRY_ENABLED=false
TELEMETRY_ENDPOINT=
HEALTH_CHECK_ENABLED=true

# ── LangSmith Tracing ───────────────────────────────────────
# LANGSMITH_TRACING=false
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=lsv2_pt_...
# LANGSMITH_PROJECT=edms-ai-assistant

# ── EDMS Plugin (WXT/Vite) ────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_EDMS_FRONTEND_URL=https://next.edo.iba

VITE_LLM_GENERATIVE_URL=http://model-generative.shared.du.iba/v1
VITE_LLM_GENERATIVE_MODEL=generative-model
VITE_LLM_EMBEDDING_URL=http://model-embedding.shared.du.iba/v1
VITE_LLM_EMBEDDING_MODEL=embedding-model
VITE_LLM_TEMPERATURE=0.0
VITE_LLM_MAX_TOKENS=2048
VITE_LLM_TIMEOUT=120
VITE_LLM_MAX_RETRIES=3

VITE_AGENT_MAX_ITERATIONS=10
VITE_AGENT_MAX_CONTEXT_MESSAGES=20
VITE_AGENT_TIMEOUT=120
VITE_AGENT_MAX_RETRIES=3
VITE_AGENT_ENABLE_TRACING=false
VITE_AGENT_LOG_LEVEL=INFO

VITE_RAG_CHUNK_SIZE=1200
VITE_RAG_CHUNK_OVERLAP=300
VITE_RAG_BATCH_SIZE=20
VITE_RAG_EMBEDDING_BATCH_SIZE=10

VITE_EDMS_BASE_URL=http://127.0.0.1:8098
VITE_EDMS_TIMEOUT=120
VITE_EDMS_API_VERSION=v1